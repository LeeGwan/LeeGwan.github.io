source "https://rubygems.org"

# GitHub Pages 가 실제로 사용하는 버전 묶음을 그대로 씁니다.
# 이렇게 하면 "내 컴퓨터 미리보기"와 "실제 사이트"가 똑같이 나옵니다.
gem "github-pages", group: :jekyll_plugins

# 윈도우/맥에서 가끔 필요한 보조 젬들
gem "webrick", "~> 1.8"

platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end
